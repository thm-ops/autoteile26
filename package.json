{
  "name": "autoteile26",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/config/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "dev": "cp -n .env.default .env && docker compose -f docker-compose.dev.yml up --build",
    "prod": "cp -n .env.default .env && docker compose -f docker-compose.prod.yml up --build",
    "stop": "docker compose -f docker-compose.dev.yml down && docker compose -f docker-compose.prod.yml down",
    "stop:dev": "docker compose -f docker-compose.dev.yml down",
    "stop:prod": "docker compose -f docker-compose.prod.yml down",
    "build": "npm run build --workspaces --if-present",
    "start:web": "npm run start --workspace=@autoteile26/web",
    "dev:web": "npm run dev --workspace=@autoteile26/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "setup": "cp .env.default .env"
  },
  "license": "MIT"
}
