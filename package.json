{
  "name": "autoteile26",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/config/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start:web": "npm run start --workspace=@autoteile26/web",
    "dev:web": "npm run dev --workspace=@autoteile26/web",
    "test": "vitest run",
    "lint": "npm run lint --workspaces --if-present",
    "setup": "cp .env.default .env"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5"
  }
}
