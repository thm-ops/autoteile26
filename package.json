{
  "type": "module",
  "name": "autoteile26",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/config/*",
    "packages/apps/*",
    "packages/libs/*"
  ],
  "scripts": {
    "dev": "npm run copy_env_web && docker compose -f docker-compose.dev.yml up -d && concurrently -n \"next,service\" \"npm run dev:web\" \"npm run start:dev:service\"",
    "prod": "docker compose up --build",
    "start": "docker-compose up --build",
    "clean": "npm run clean --workspaces --if-present",
    "start:dev": "docker compose -f docker-compose.dev.yml start",
    "start:prod": "docker compose -f docker-compose.yml start",
    "stop": "npm run stop:dev && npm run stop:prod",
    "stop:dev": "docker compose -f docker-compose.dev.yml stop",
    "stop:prod": "docker compose -f docker-compose.yml stop",
    "down": "npm run down:dev && npm run down:prod",
    "down:dev": "docker compose -f docker-compose.dev.yml down",
    "down:prod": "docker compose -f docker-compose.yml down",
    "build": "npm run copy_env_web && npm run build --workspaces --if-present",
    "build:web": "npm run copy_env_web && npm run build --workspace=@autoteile26/web",
    "start:web": "npm run copy_env_web && npm run start --workspace=@autoteile26/web",
    "dev:web": "npm run copy_env_web && npm run dev --workspace=@autoteile26/web",
    "test": "npm run test --workspaces --if-present",
    "test:web": "npm run test --workspace=@autoteile26/web",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0 --config .eslintrc.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint:web": "npm run lint --workspace=@autoteile26/web",
    "setup": "shx cp .env.default .env",
    "build:service": "npm run build --workspace=@autoteile26/service",
    "format:service": "npm run format --workspace=@autoteile26/service",
    "start:service": "npm run start --workspace=@autoteile26/service",
    "start:dev:service": "npm run start:dev --workspace=@autoteile26/service",
    "start:debug:service": "npm run start:debug --workspace=@autoteile26/service",
    "start:prod:service": "npm run start:prod --workspace=@autoteile26/service",
    "lint:service": "npm run lint --workspace=@autoteile26/service",
    "test:service": "npm run test --workspace=@autoteile26/service",
    "test:watch:service": "npm run test:watch --workspace=@autoteile26/service",
    "test:cov:service": "npm run test:cov --workspace=@autoteile26/service",
    "test:debug:service": "npm run test:debug --workspace=@autoteile26/service",
    "test:e2e:service": "npm run test:e2e --workspace=@autoteile26/service",
    "migration:run:service": "npm run migration:run --workspace=@autoteile26/service",
    "migration:revert:service": "npm run migration:revert --workspace=@autoteile26/service",
    "migration:show:service": "npm run migration:show --workspace=@autoteile26/service",
    "copy_env_web": "cp .env packages/apps/web/.env"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^10.0.0",
    "bcrypt": "^6.0.0",
    "next-auth": "^4.24.14"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "*",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  }
}
