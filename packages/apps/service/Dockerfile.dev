# Dockerfile for the autoteile26 service application
#
# This Dockerfile sets up a development environment for the
# autoteile26 service application using Node.js and Alpine Linux.
#
# Features:
# - Uses a lightweight Alpine-based Node.js image
# - Uses the non-root 'node' user for improved security
# - Uses Docker build cache for faster dependency installation
# - Starts the Nest.js development server with debugging enabled on port 3000

# Using the Node.js image with the specified version from the .env file
ARG NODE_VERSION=24-alpine
FROM node:${NODE_VERSION}

LABEL maintainer="noelhoppe" \
    version="1.0" \
    environment="dev" \
    decription="Docker image for the autoteile26 service application"

# Set the working directory inside the container
WORKDIR /packages/apps/service

# Copy package.json and package-lock.json to the working directory
COPY --chown=node:node package-lock.json .
COPY --chown=node:node packages/apps/service/package.json .

# Install dependencies using Docker cache mount
RUN --mount=type=cache,target=/root/.npm \
    npm ci

# Copy the rest of the application files (exluding node_modules) to the working directory
COPY packages/apps/service .

# Use non-root user for better security
USER node

# Expose the application port
EXPOSE 3000

# Start the development server with debugging enabled
CMD ["npm", "run", "start:debug"]
