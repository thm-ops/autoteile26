# Dockerfile for the autoteile26 web application
#
# This Dockerfile sets up a development environment for the
# autoteile26 web application using Node.js and Alpine Linux.
#
# Features:
# - Uses a lightweight Alpine-based Node.js image
# - Uses the non-root 'node' user for improved security
# - Uses Docker build cache for faster dependency installation
# - Starts the Next.js development server on port 3000

ARG NODE_VERSION=24-alpine
FROM node:${NODE_VERSION}

LABEL maintainer="volknichtx" \
      version="1.0" \
      environment="dev" \
      description="Docker image for the autoteile26 web application"

# Set working directory
WORKDIR /app

# Copy package manifests first for better layer caching
COPY --chown=node:node package*.json ./
COPY --chown=node:node packages/apps/web/package*.json ./packages/apps/web/

# Install dependencies using Docker cache mount
RUN --mount=type=cache,target=/root/.npm npm ci

# Copy application source code
COPY --chown=node:node . .

# Use non-root user
USER node

# Expose development server port
ARG APP_PORT=3000
EXPOSE ${APP_PORT}

# Start the Next.js development server
CMD ["npm", "run", "dev"]